// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model IngredientCategory {
  id          Int          @id @default(autoincrement())
  title       String       @unique
  ingredients Ingredient[] // A category can have many ingredients
}

model RecipeCategory {
  id      Int      @id @default(autoincrement())
  title   String   @unique
  recipes Recipe[] // A category can have many ingredients
}

model Ingredient {
  id          Int     @id @default(autoincrement())
  title       String  @unique
  description String?

  imageKey     String?
  imageVersion Int     @default(0)

  isAdded   Boolean  @default(false)
  isInStock Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign key and Relation definitions
  categoryId        Int
  category          IngredientCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
}

model Recipe {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  notes       String

  imageKey     String?
  imageVersion Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients      RecipeIngredient[]
  recipeCategory   RecipeCategory     @relation(fields: [recipeCategoryId], references: [id])
  recipeCategoryId Int
}

model RecipeIngredient {
  recipeId     Int
  ingredientId Int

  amount String

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([recipeId, ingredientId])
}
