// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model IngredientCategory {
  id          Int          @id @default(autoincrement())
  title       String       @unique
  ingredients Ingredient[] // A category can have many ingredients
}

model RecipeCategory {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String   @default("")
  recipes     Recipe[] // A category can have many ingredients
}

model Ingredient {
  id          Int     @id @default(autoincrement())
  title       String  @unique
  description String?

  imageKey     String?
  imageVersion Int     @default(0)

  isSaved   Boolean  @default(false)
  isInStock Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign key and Relation definitions
  categoryId        Int
  category          IngredientCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  recipeIngredients RecipeIngredient[]
}

enum RecipeSeries {
  DEFAULT
  NOMLYGOLD
}

model Recipe {
  id          Int    @id @default(autoincrement())
  title       String @unique
  description String
  notes       String

  inStock Int     @default(0)
  isSaved Boolean @default(false)

  isConfirmed       Boolean @default(false)
  confirmationNotes String?

  imageKey     String?
  imageVersion Int     @default(0)

  spicy  Int          @default(0)
  series RecipeSeries @default(DEFAULT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients      RecipeIngredient[]
  recipeCategory   RecipeCategory     @relation(fields: [recipeCategoryId], references: [id], onDelete: Restrict)
  recipeCategoryId Int
  withlistItems    WithlistItem[]
}

model RecipeIngredient {
  recipeId     Int
  ingredientId Int

  amount String

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([recipeId, ingredientId])
}

model StuffCategory {
  id    Int     @id @default(autoincrement())
  title String  @unique
  stuff Stuff[]
}

model Stuff {
  id          Int     @id @default(autoincrement())
  title       String  @unique
  description String?
  inStock     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stuffCategory   StuffCategory @relation(fields: [stuffCategoryId], references: [id], onDelete: Restrict)
  stuffCategoryId Int
}

enum Role {
  USER
  ADMIN
}

model User {
  id Int @id @default(autoincrement())

  email String @unique
  name  String

  role Role @default(USER)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  withlistItems WithlistItem[]
}

model WithlistItem {
  id Int @id @default(autoincrement())

  userId   Int
  recipeId Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
  @@index([recipeId])
}
